# Sensus — PL_Genesis Hackathon 2026
# Copy this file to .env and fill in your API keys

# Storacha (https://console.storacha.network/)
STORACHA_TOKEN=your_storacha_token_here

# web3.storage / Filecoin (https://web3.storage/)
WEB3_STORAGE_TOKEN=your_web3storage_token_here

# Impulse AI (https://www.impulselabs.ai/)
IMPULSE_API_KEY=your_impulse_api_key_here

# Optional: Gemini API (for AI health interpretation)
GEMINI_API_KEY=your_gemini_key_here

# Optional: ElevenLabs (for voice alerts)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
